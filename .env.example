# === CREDENCIALES OAuth 2.0 MERCADO LIBRE ===
# Obtén estos valores en: https://developers.mercadolibre.com.mx/devcenter
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REFRESH_TOKEN=

# === CREDENCIALES AFILIADO MERCADO LIBRE ===
# Obtén estos valores en: https://www.mercadolibre.com.mx/afiliados
ML_MATT_TOOL=
ML_MATT_WORD=

# === CONTROL ESTACIONAL ===
IS_HOT_SALE=false

# === OFERTAS RELÁMPAGO (runtime) ===
# Fuente del JSON de relámpago, leída por el cliente en runtime (PUBLIC_ = se
# expone al navegador). En dev/prod por defecto sirve el placeholder local;
# en prod apúntala a tu KV/R2/CDN externo para refrescar SIN rebuild.
PUBLIC_RELAMPAGO_URL=/data/relampago.json

# === BOLETÍN + CONTACTO (Cloudflare Pages Functions) ===
# Secreto para firmar el token HMAC de doble opt-in del boletín (genera uno
# largo y aleatorio; NO lo compartas). Sin él, /api/subscribe falla controlado.
SUBSCRIBE_SECRET=
# API key del ESP (Resend por defecto) para enviar correos transaccionales.
RESEND_API_KEY=
# Remitente verificado en el ESP (debe ser un dominio verificado en Resend).
EMAIL_FROM=KalidaPresio <hola@tudominio.com>
# Bandeja de soporte que recibe los mensajes del formulario de contacto.
SUPPORT_INBOX=soporte@tudominio.com
# URL pública del sitio (para construir el link de confirmación del boletín).
PUBLIC_SITE_URL=https://kalidapresio.com
