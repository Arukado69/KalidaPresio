---
/**
 * SelloKP — Anillo de progreso "Calidad-Precio" con escala visual por valor.
 * El color Y la intensidad del glow crecen con el score, así un 99 se siente
 * distinto de un 80. A partir de 90 añade un pulso sutil ("top").
 *
 * Con `tooltip` el sello se vuelve interactivo: hover/focus muestran la
 * leyenda explicativa y en táctil un tap la revela (el toggle vive en
 * Layout → bindKpTips, delegado para sobrevivir a las View Transitions).
 * Respeta prefers-reduced-motion (sin animación).
 */
export interface Props {
  score: number;
  size?: number;
  /** Pulso extra del anillo. Reservado para el destacado (no para cada tarjeta). */
  pulse?: boolean;
  /** Muestra la leyenda "qué significa K-P" al hover/tap. Úsalo en cards. */
  tooltip?: boolean;
  /** Lado donde se ancla la burbuja: 'end' (derecha, default) o 'start'. */
  tipAlign?: 'end' | 'start';
}

const { score, size = 96, pulse = false, tooltip = false, tipAlign = 'end' } = Astro.props;

const clamped = Math.max(0, Math.min(100, Math.round(score)));

// Geometría del anillo
const stroke = Math.max(6, Math.round(size * 0.09));
const radius = (size - stroke) / 2;
const center = size / 2;
const circumference = 2 * Math.PI * radius;
const offset = circumference * (1 - clamped / 100);

// ── Escala visual por valor ──────────────────────────────────────────────────
// Hue por tramo (verde alto / ámbar cálido medio / rojo bajo)
const color = clamped >= 70 ? '#1fd28e' : clamped >= 55 ? '#e9b86d' : '#ff6b6b';
// Glow CONTINUO según el valor exacto → 99 brilla más que 90, y 90 más que 80
const glow = Math.round(4 + (Math.max(0, Math.min(clamped, 100) - 60) / 40) * 16);
// Tier solo para accesibilidad/etiqueta
const tier = clamped >= 90 ? 'Excepcional' : clamped >= 80 ? 'Excelente' : clamped >= 70 ? 'Buena' : clamped >= 55 ? 'Aceptable' : 'Baja';
const top = pulse;

// Leyenda K-P (COPY FIJO — no editar)
const LEYENDA = 'Sello Kalidad-Precio: combina la calidad real según los compradores con el descuento real. Mientras más alto, mejor es la compra.';

// Tamaños tipográficos proporcionales al sello
const numFont = (size * 0.32).toFixed(1);
const labelFont = (size * 0.135).toFixed(1);

// Atributos interactivos solo cuando hay tooltip (tap/teclado equivalente al hover)
const interactivos = tooltip
  ? { 'data-kp-tip': true, tabindex: 0, role: 'button', 'aria-expanded': 'false' }
  : { role: 'img' };
---

<div
  class={`kp-sello${top ? ' kp-top' : ''}${tooltip ? ' kp-has-tip' : ''}${tipAlign === 'start' ? ' kp-tip-start' : ''}`}
  style={`--kp-size:${size}px; --kp-color:${color}; --kp-glow:${glow}px; --kp-circ:${circumference.toFixed(2)}px; --kp-offset:${offset.toFixed(2)}px;`}
  aria-label={`Sello calidad-precio: ${clamped} de 100 (${tier})${tooltip ? '. Toca para ver qué significa.' : ''}`}
  {...interactivos}
>
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} class="kp-svg" aria-hidden="true">
    <circle
      class="kp-ring-track"
      cx={center}
      cy={center}
      r={radius}
      fill="none"
      stroke-width={stroke}
    />
    <circle
      class="kp-ring-progress"
      cx={center}
      cy={center}
      r={radius}
      fill="none"
      stroke={color}
      stroke-width={stroke}
      stroke-linecap="round"
      stroke-dasharray={circumference.toFixed(2)}
      transform={`rotate(-90 ${center} ${center})`}
    />
  </svg>

  <div class="kp-centro" aria-hidden="true">
    <span class="kp-num" style={`font-size:${numFont}px; color:${color};`}>{clamped}</span>
    <span class="kp-label" style={`font-size:${labelFont}px;`}>K-P</span>
  </div>

  {tooltip && <span class="kp-tip-bubble" role="tooltip">{LEYENDA}</span>}
</div>

<style>
  .kp-sello {
    position: relative;
    width: var(--kp-size);
    height: var(--kp-size);
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
  }

  .kp-svg {
    display: block;
  }

  .kp-ring-track {
    stroke: rgba(255, 255, 255, 0.08);
  }

  .kp-ring-progress {
    /* Estado final (también el estado base si no hay animación) */
    stroke-dashoffset: var(--kp-offset);
    animation: kp-fill 1.1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    /* El glow crece con el score → 99 brilla más que 80.
       (El sello K-P es una de las 3 zonas donde el glow está permitido.) */
    filter: drop-shadow(0 0 var(--kp-glow, 6px) var(--kp-color));
  }

  /* Score 90+ : pulso sutil del anillo para destacar lo excepcional */
  .kp-top .kp-ring-progress {
    animation: kp-fill 1.1s cubic-bezier(0.4, 0, 0.2, 1) forwards,
               kp-topglow 2.6s ease-in-out 1.1s infinite;
  }
  @keyframes kp-topglow {
    0%, 100% { filter: drop-shadow(0 0 calc(var(--kp-glow) * 0.7) var(--kp-color)); }
    50%      { filter: drop-shadow(0 0 calc(var(--kp-glow) * 1.4) var(--kp-color)); }
  }

  .kp-centro {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    gap: 0.12em;
  }

  .kp-num {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .kp-label {
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  /* === Leyenda explicativa (tooltip + equivalente táctil) === */
  .kp-has-tip { cursor: help; }

  .kp-tip-bubble {
    position: absolute;
    bottom: calc(100% + 10px);
    right: 0;
    width: 228px;
    padding: 0.65rem 0.8rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface-raised);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-md);
    color: var(--color-text);
    font-size: 0.76rem;
    font-weight: 500;
    line-height: 1.5;
    text-align: left;
    letter-spacing: 0;
    text-transform: none;
    z-index: 30;
    /* Oculto por defecto; solo transform/opacity (cero reflow, cero CLS) */
    opacity: 0;
    transform: translateY(6px) scale(0.97);
    transform-origin: bottom right;
    pointer-events: none;
    transition: opacity var(--dur-med) var(--ease-out-expo),
                transform var(--dur-med) var(--ease-out-expo);
  }

  /* Burbuja anclada al lado izquierdo (cuando el sello está pegado al borde) */
  .kp-tip-start .kp-tip-bubble {
    right: auto;
    left: 0;
    transform-origin: bottom left;
  }

  /* Hover (desktop), foco (teclado) y .is-open (tap — lo pone bindKpTips) */
  .kp-has-tip:hover .kp-tip-bubble,
  .kp-has-tip:focus-visible .kp-tip-bubble,
  .kp-has-tip.is-open .kp-tip-bubble {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  @keyframes kp-fill {
    from { stroke-dashoffset: var(--kp-circ); }
    to   { stroke-dashoffset: var(--kp-offset); }
  }

  @media (prefers-reduced-motion: reduce) {
    .kp-ring-progress,
    .kp-top .kp-ring-progress {
      animation: none;
      stroke-dashoffset: var(--kp-offset);
    }
    .kp-tip-bubble { transition: opacity 0.001ms; }
  }
</style>
