---
import Layout from '../layouts/Layout.astro';
import SelloKP from '../components/SelloKP.astro';
import Estrellas from '../components/Estrellas.astro';
import BotonCTA from '../components/BotonCTA.astro';
import RelampagoSticky from '../components/RelampagoSticky.astro';
import ImbatiblesGrid from '../components/ImbatiblesGrid.astro';
import { generarVeredicto, tierKP } from '../utils/veredicto.js';
import ofertas from '../data/ofertas.json';
// Colecciones por sección (build-time, con fallback a ofertas.json si el
// extractor aún no corrió). Relámpago e Imbatibles son el MVP; liquidación
// y menos-500 quedan en backlog (los datos ya existen).
// Relámpago ya NO se importa: es runtime (RelampagoSticky + initRelampagoFetch).
import { ALL_IMBATIBLES } from '../data/secciones.js';

const isHotSale = import.meta.env.IS_HOT_SALE === 'true';

// ════════════════════════════════════════════════════════
// SCORING — Mismo algoritmo que n8n (importarOfertas.js ya lo calcula y ordena).
// Aquí solo reordenamos de forma defensiva por si el JSON se edita a mano.
//   Rating 65% · Descuento 20% (tope 40) · Volumen 15% (tope 500)
// ════════════════════════════════════════════════════════
function scoreDe(o) {
  if (typeof o.score_kalidad_presio === 'number') return o.score_kalidad_presio;
  const r = ((o.rating ?? 0) / 5) * 65;
  const d = (Math.min(o.descuento ?? 0, 40) / 40) * 20;
  const op = Math.min(((o.opiniones ?? 0) / 500) * 15, 15);
  return Math.round(r + d + op);
}

const ofertasScored = ofertas
  .map((o) => ({ ...o, score100: scoreDe(o) }))
  // Mismo criterio que el scraper: K-P y, ante empate, mayor confianza.
  .sort((a, b) => b.score100 - a.score100 || (b.confianza ?? 0) - (a.confianza ?? 0));

// El feed de ofertas.json (build-time) alimenta showpiece + bento + imbatibles.
// Las relámpago se sirven aparte en runtime (no entran aquí).
const evergreen = ofertasScored.filter((o) => !o.oferta_relampago);

// PRODUCTO DEL DÍA (showpiece del hero): la oferta más perfecta —
// mayor K-P y, ante empate, mayor descuento real. Se excluye del bento
// para no repetirla.
const showpiece = [...evergreen].sort(
  (a, b) => b.score100 - a.score100 || (b.descuento ?? 0) - (a.descuento ?? 0)
)[0];
const restantes = evergreen.filter((o) => o !== showpiece);

const veredicto = restantes[0];        // hero del bento (tile grande)
const bentoSmall = restantes.slice(1, 5); // 4 tiles que rodean al hero
// (el viejo "resto" para el catálogo murió: ahora el catálogo es IMBATIBLES)

// Datos derivados del showpiece
const spDescuento = showpiece ? Math.round(showpiece.descuento ?? 0) : 0;
const spPrev = showpiece
  ? (showpiece.precio_previo ??
     (spDescuento > 0 ? Math.round(showpiece.precio_actual / (1 - spDescuento / 100)) : null))
  : null;

// (categorizar vive ahora en src/utils/categorias.js; lo usa ImbatiblesGrid)

const fmt = (n) =>
  new Intl.NumberFormat('es-MX', {
    style: 'currency',
    currency: 'MXN',
    maximumFractionDigits: 0,
  }).format(n);

// Datos derivados del veredicto del día
const vInicial = veredicto ? (veredicto.titulo?.trim()?.charAt(0) ?? '?').toUpperCase() : '?';
const vDescuento = veredicto ? Math.round(veredicto.descuento ?? 0) : 0;
const vPrecioOriginal = veredicto
  ? (veredicto.precio_previo ??
     (vDescuento > 0 ? Math.round(veredicto.precio_actual / (1 - vDescuento / 100)) : null))
  : null;

const vConfianza = veredicto?.confianza ?? 0;
const vConfNivel = vConfianza >= 80 ? 'Alta' : vConfianza >= 50 ? 'Media' : 'Básica';
const vConfClase = vConfianza >= 80 ? 'alta' : vConfianza >= 50 ? 'media' : 'basica';

// Tier + veredicto editorial del destacado (lógica compartida en utils/veredicto.js)
const vTier = veredicto ? tierKP(veredicto.score100) : '';
const vVeredicto = veredicto ? generarVeredicto(veredicto) : '';
---

<Layout
  title="KalidaPresio | Las mejores ofertas calidad-precio de Mercado Libre"
  description="Feed diario de ofertas en Mercado Libre México, ordenadas por nuestro sello calidad-precio. Sin publicidad disfrazada."
>
  <!-- Hero / Módulo estacional -->
  <section class={`banner-estacional ${isHotSale ? 'modo-oferta' : 'modo-limpio'}`}>
    {isHotSale ? (
      <div class="alerta-hotsale">
        <h2 class="oferta-neon">🔥 ¡HOT SALE ACTIVO! 🔥</h2>
        <p class="oferta-texto">Precios históricos en tecnología. Verifica el stock en tiempo real.</p>
      </div>
    ) : (
      <!-- HERO SPLIT: texto a la izquierda + Producto del día a la derecha.
           La entrada la orquesta GSAP (timeline en Layout): líneas del título
           enmascaradas que "suben", cascada de elementos, showpiece desde la
           derecha con pop del sello K-P. -->
      <div class="hero-grid">
        <div class="hero-content">
          <div class="hero-badge">⚡ Ofertas reales de Mercado Libre México</div>
          <h1 class="hero-titulo">
            <span class="hero-mask"><span class="hero-line">Solo las ofertas que</span></span>
            <span class="hero-mask"><span class="hero-line hero-acento">de verdad valen la pena.</span></span>
          </h1>
          <p class="hero-subtitulo">
            Rastreamos miles de ofertas y te mostramos únicamente las mejores según nuestro
            <strong> Sello K-P</strong>: calidad real de los compradores + descuento real. Sin relleno.
          </p>

          <div class="hero-pills">
            <span class="hero-pill"><span class="dot"></span> Cero anuncios pagados</span>
            <span class="hero-pill"><span class="dot"></span> Datos reales de ML</span>
            <span class="hero-pill"><span class="dot"></span> Actualizado a diario</span>
          </div>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="stat-numero" data-countup={ofertas.length}>0</span>
              <span class="stat-label">Ofertas curadas</span>
            </div>
            <!-- Stat de relámpago: ahora runtime. Oculto al inicio; el fetch
                 lo rellena y muestra si hay ofertas vivas (initRelampagoFetch). -->
            <div class="hero-stat-divider" data-relampago-statwrap hidden></div>
            <div class="hero-stat" data-relampago-statwrap hidden>
              <span class="stat-numero" data-relampago-stat>0</span>
              <span class="stat-label">⚡ Relámpago hoy</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="stat-numero" data-countup="100" data-suffix="%">0%</span>
              <span class="stat-label">Calidad-precio</span>
            </div>
          </div>
        </div>

        {showpiece && (
          <aside class="hero-show" aria-label="Producto del día">
            <!-- Halo de marca detrás del producto (pulsa lento, solo opacity) -->
            <div class="hs-glow" aria-hidden="true"></div>

            <div class="hs-media">
              <img
                src={showpiece.imagen}
                alt={showpiece.titulo}
                class="hs-img"
                loading="eager"
                fetchpriority="high"
                onerror="this.style.visibility='hidden'"
              />
              {spDescuento > 0 && <span class="hs-desc">-{spDescuento}%</span>}
              <!-- Sello K-P prominente, medio fuera del marco (entra con pop) -->
              <div class="hs-kp">
                <SelloKP score={showpiece.score100} size={76} pulse tooltip tipAlign="start" />
              </div>
            </div>

            <div class="hs-datos">
              <span class="hs-eyebrow">★ Producto del día</span>
              <h2 class="hs-titulo">{showpiece.titulo}</h2>
              <div class="hs-precios">
                <span class="hs-precio">{fmt(showpiece.precio_actual)}</span>
                {spPrev && <s class="hs-prev">{fmt(spPrev)}</s>}
              </div>
              <div class="hs-rating">
                <Estrellas rating={showpiece.rating} size={14} />
                <strong>{showpiece.rating?.toFixed(1)}</strong>
                <em>({showpiece.opiniones?.toLocaleString('es-MX')} opiniones)</em>
              </div>
              <BotonCTA id={showpiece.id} enlace={showpiece.link_afiliado} texto="Ver oferta" magnetic />
            </div>
          </aside>
        )}
      </div>
    )}
  </section>

  <!-- RELÁMPAGO móvil/tablet: franja colapsable bajo el hero (tap revela).
       Datos en RUNTIME: el componente muestra skeleton y el cliente lo llena
       (o muestra su empty-state). En desktop vive en el rail sticky izquierdo. -->
  <div class="solo-movil">
    <RelampagoSticky modo="strip" />
  </div>

  <!-- Layout 2 columnas: rail relámpago STICKY (izq, desktop) + contenido.
       El rail queda siempre visible al scrollear bento + imbatibles. -->
  <div class="kp-shell">
    <aside class="kp-aside">
      <RelampagoSticky modo="rail" />
    </aside>

    <div class="kp-main">

  <!-- Bento: top calidad-precio (hero grande + tiles que lo rodean) -->
  {veredicto && (
    <section class="seccion-estructural bento-section" data-reveal>
      <h2 class="titulo-seccion">🏆 Top calidad-precio de hoy</h2>

      <div class="bento">
        <!-- Tile hero (oferta #1 evergreen). data-tilt: se inclina hacia el cursor -->
        <article class="bento-hero" data-spotlight data-tilt>
          <div class="bh-media">
            <img
              src={veredicto.imagen}
              alt={veredicto.titulo}
              loading="lazy"
              class="bh-img"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <span class="bh-fallback" aria-hidden="true">{vInicial}</span>
            {veredicto.mas_vendido ? (
              <span class="veredicto-badge badge-vendido">★ MÁS VENDIDO</span>
            ) : vDescuento > 0 ? (
              <span class="veredicto-badge">-{vDescuento}%</span>
            ) : null}
          </div>

          <div class="bh-info">
            <span class="bh-eyebrow">⚡ Veredicto del día</span>
            <!-- Título clicable: la card siempre tiene enlace a la vista,
                 aunque el CTA quede bajo el pliegue en pantallas chicas -->
            <h3 class="bh-titulo">
              <a class="bh-titulo-link" href={veredicto.link_afiliado} target="_blank" rel="nofollow sponsored noopener noreferrer">{veredicto.titulo}</a>
            </h3>

            <!-- El PRECIO va antes del bloque narrativo: es lo primero que
                 busca el usuario y nunca debe quedar tapado ni recortado -->
            <div class="bh-precios">
              <span class="bh-precio">{fmt(veredicto.precio_actual)}</span>
              {vPrecioOriginal && <s class="bh-prev">{fmt(vPrecioOriginal)}</s>}
            </div>

            <!-- Unidad narrativa del Sello K-P: score + por qué + señales reales -->
            <div class="bh-verdict">
              <div class="bh-kp"><SelloKP score={veredicto.score100} size={86} pulse tooltip tipAlign="start" /></div>
              <div class="bh-verdict-body">
                <span class="bh-tier">{vTier} <em>· calidad-precio</em></span>
                <p class="bh-why">{vVeredicto}</p>
                <div class="bh-signals">
                  <span class="bh-signal">
                    <Estrellas rating={veredicto.rating} size={13} />
                    <strong>{veredicto.rating?.toFixed(1)}</strong>
                    <em>({veredicto.opiniones?.toLocaleString('es-MX')})</em>
                  </span>
                  {vDescuento > 0 && <span class="bh-signal bh-dscto">−{vDescuento}% real</span>}
                </div>
              </div>
            </div>

            <BotonCTA id={veredicto.id} enlace={veredicto.link_afiliado} texto="Ver oferta" />
          </div>
        </article>

        <!-- Tiles pequeños (siguientes mejores), en su propio wrapper:
             el bento es flex hero|tiles — sin filas compartidas que Chrome
             se niegue a estirar (causa raíz del recorte/solape) -->
        <div class="bento-tiles">
        {bentoSmall.map((o) => (
          <a
            class="bento-tile"
            data-spotlight
            data-ripple
            href={o.link_afiliado}
            target="_blank"
            rel="nofollow sponsored noopener noreferrer"
          >
            <div class="bt-media">
              <img src={o.imagen} alt={o.titulo} loading="lazy" class="bt-img" onerror="this.style.visibility='hidden'" />
              {o.descuento > 0 && <span class="bt-desc">-{Math.round(o.descuento)}%</span>}
              <!-- Chip K-P con contexto: número + etiqueta + escala de color.
                   El title da la leyenda en desktop (el tile es un enlace, no
                   admite el tooltip interactivo del sello). -->
              <span
                class="bt-kp"
                style={`--kp-c:${o.score100 >= 70 ? 'var(--color-primary)' : o.score100 >= 55 ? 'var(--color-warm)' : '#ff6b6b'}`}
                title="Sello Kalidad-Precio: combina la calidad real según los compradores con el descuento real. Mientras más alto, mejor es la compra."
              >
                <strong>{Math.round(o.score100)}</strong>
                <em>K-P</em>
              </span>
            </div>
            <div class="bt-info">
              <h4 class="bt-titulo">{o.titulo}</h4>
              <span class="bt-precio">{fmt(o.precio_actual)}</span>
              <span class="bt-cta">Ver oferta →</span>
            </div>
          </a>
        ))}
        </div><!-- /.bento-tiles -->
      </div>
    </section>
  )}

  <!-- Catálogo principal: IMBATIBLES (grid 3/2/1, score recalibrado 65/10/25).
       Liquidación y menos-500: datos listos en secciones.js, render en el
       siguiente sprint (backlog). -->
  <ImbatiblesGrid productos={ALL_IMBATIBLES} />

    </div><!-- /.kp-main -->
  </div><!-- /.kp-shell -->
</Layout>

<style>
  /* =========================================
     Hero / Módulo estacional
     ========================================= */
  .banner-estacional {
    border-radius: var(--radius-lg);
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  /* Hero reducido ~80%: menos padding y tipografía, misma fuerza de mensaje.
     Es UNA de las 3 zonas con glow permitido (auroras verde + ámbar). */
  .modo-limpio {
    background: linear-gradient(
      135deg,
      var(--color-surface) 0%,
      rgba(120, 80, 255, 0.06) 50%,
      var(--color-surface) 100%
    );
    border: 1px solid var(--color-violet-border);
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    padding: clamp(1.6rem, 4.5vw, 3.1rem) clamp(1.25rem, 4vw, 2.75rem);
    position: relative;
    overflow: hidden;
  }

  .modo-limpio::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -10%;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle at top right, rgba(31, 210, 142, 0.09) 0%, transparent 65%);
    pointer-events: none;
    animation: kp-aurora 16s ease-in-out infinite;
  }

  /* Aurora violeta de marca: el hero respira en los colores del logo */
  .modo-limpio::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle at bottom left, rgba(130, 90, 255, 0.12) 0%, transparent 65%);
    pointer-events: none;
    animation: kp-aurora 20s ease-in-out infinite reverse;
  }

  /* === HERO SPLIT: texto izquierda / showpiece derecha === */
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    align-items: center;
    text-align: left; /* el split abandona el centrado */
  }
  @media (min-width: 920px) {
    .hero-grid { grid-template-columns: 1.08fr 0.92fr; }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  /* === Showpiece: Producto del día === */
  .hero-show {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 400px;
    width: 100%;
    margin-inline: auto;   /* móvil: centrado bajo el texto */
    justify-self: center;
  }

  /* Halo violeta+verde detrás del producto: pulsa SOLO con opacity */
  .hs-glow {
    position: absolute;
    inset: -12% -8% auto;
    height: 78%;
    border-radius: 50%;
    background:
      radial-gradient(closest-side, rgba(130, 90, 255, 0.22), transparent 75%),
      radial-gradient(closest-side at 70% 30%, rgba(31, 210, 142, 0.12), transparent 70%);
    filter: blur(6px);
    pointer-events: none;
    animation: kp-glow-pulse 4.5s var(--ease-soft) infinite;
  }

  /* Marco blanco cuadrado: la foto de ML en su formato nativo, sin recorte.
     overflow visible → el sello sobresale y la burbuja del tooltip respira. */
  .hs-media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: visible;
  }
  .hs-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: clamp(1rem, 5cqw, 1.6rem);
    will-change: transform; /* flota en idle (GSAP) */
  }
  .hs-desc {
    position: absolute;
    top: 14px;
    left: 14px;
    background-color: var(--color-error);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 900;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }
  /* Sello K-P medio fuera del marco: protagonista, no decoración */
  .hs-kp {
    position: absolute;
    bottom: -16px;
    left: -14px;
    padding: 5px;
    border-radius: var(--radius-pill);
    background: var(--overlay-ink);
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    box-shadow: var(--shadow-md);
    z-index: 3;
  }

  .hs-datos {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-left: 0.25rem;
  }
  .hs-eyebrow {
    color: var(--color-accent);
    font-weight: 800;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .hs-titulo {
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    color: #fff;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hs-precios { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
  .hs-precio {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .hs-prev { font-size: 1rem; color: var(--color-text-muted); text-decoration: line-through; }
  .hs-rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .hs-rating strong { color: var(--color-text); }
  .hs-rating em { font-style: normal; }
  .hero-show :global(.cta-wrapper) { margin: var(--spacing-xs) 0 0; justify-content: flex-start; }
  .hero-show :global(.cta-button) { width: auto; padding: 0.8rem 1.8rem; }

  .hero-badge {
    display: inline-block;
    background-color: rgba(31, 210, 142, 0.08);
    border: 1px solid var(--color-primary-border);
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-pill);
    margin-bottom: var(--spacing-sm);
  }

  /* Titular monumental: grande en desktop (~3.5rem; en la columna estrecha
     del split, más allá empieza a generar huérfanos). El mínimo (2rem)
     mantiene legibilidad en móvil sin saturar <640px. */
  .hero-titulo {
    font-size: clamp(2rem, 5.2vw, 3.5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.08;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.03em;
  }

  /* Máscaras del título: cada línea "sube" desde su propio marco recortado
     (GSAP anima .hero-line con yPercent). Sin JS, las líneas se ven normales. */
  .hero-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.08em; /* aire para ascendentes/descendentes al recortar */
  }
  .hero-line {
    display: inline-block;
    text-wrap: balance; /* si una línea envuelve, reparte parejo (sin huérfanos) */
    will-change: transform;
  }

  /* Acento con gradiente verde→dorado cálido (clip de texto) */
  .hero-acento {
    background: linear-gradient(100deg, var(--color-primary) 0%, #7ce9bd 40%, var(--color-warm) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Pills de confianza (alineadas al texto, ya no centradas) */
  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.5rem;
    margin-bottom: var(--spacing-md);
  }
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
  }
  .hero-pill .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 8px var(--color-primary);
  }

  /* Subtítulo con más presencia: más grande, casi blanco (antes gris-medio
     se perdía) y con más aire de línea. El <strong> del Sello K-P resalta. */
  .hero-subtitulo {
    font-size: clamp(0.95rem, 2.4vw, 1.12rem);
    color: var(--color-text);
    max-width: 540px;
    margin: 0 0 var(--spacing-lg);
    line-height: 1.72;
  }
  .hero-subtitulo strong { color: #fff; font-weight: 700; }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .stat-numero {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
